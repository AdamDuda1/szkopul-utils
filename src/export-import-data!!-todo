async function importStorage(event: Event) {
  const input = event.target as HTMLInputElement;
  if (!input.files?.length) return;

  const file = input.files[0];
  const text = await file.text();

  try {
    const data = JSON.parse(text);
    if (typeof data !== "object" || data === null) throw new Error("Invalid JSON");

    // save to storage
    await browser.storage.local.set(data);
    console.log("Storage imported successfully!");
  } catch (err) {
    console.error("Failed to import storage:", err);
  }

  // reset input to allow re-importing same file if needed
  input.value = "";
