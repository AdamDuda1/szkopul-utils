{
  "name": "Szkopuł Utils",
  "description": "QOL improvements and additional features for the site szkopul.edu.pl",
  "version": "1.3",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Szkopuł Utils"
  },
  "host_permissions": ["*://szkopul.edu.pl/*", "https://czywyjebalohomika.xyz/*"],
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://szkopul.edu.pl/*"],
      "js": ["worker.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@szkopul-utils",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}