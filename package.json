{
    "scripts": {
        "build:ts": "tsc -p tsconfig.json",
        "build:worker": "esbuild src/worker.ts --bundle --format=iife --outfile=src/worker.js",
        "build:misc-fiexs": "esbuild src/misc-fixes.ts --bundle --format=esm --outfile=src/worker.js",
        "build:ui-elements": "esbuild src/ui-elements.ts --bundle --format=esm --outfile=src/worker.js",
        "build:ui-hiders": "esbuild src/ui-elements.ts --bundle --format=esm --outfile=src/worker.js",
        "build:panel": "esbuild src/panel.ts --bundle --format=esm --outfile=src/panel.js",
        "build": "npm run build:ts && npm run build:ui-elements && npm run build:ui-hiders && npm run build:misc-fiexs && npm run build:worker && npm run build:panel",
        "postinstall": "node scripts/copy-shoelace.js"
    },
    "devDependencies": {
        "@types/chrome": "^0.1.37",
        "@types/firefox-webext-browser": "^143.0.0",
        "@types/webextension-polyfill": "^0.12.5",
        "esbuild": "^0.27.4",
        "webextension-polyfill": "^0.12.0"
    },
    "dependencies": {
        "bootstrap": "^5.3.8",
        "lit": "^3.3.2"
    }
}
